PORT=2567
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=604800
AUTH_ALLOW_DEV_TOKENS=true

# Single WeChat Mini Game credentials.
WECHAT_MINIGAME_APP_ID=
WECHAT_MINIGAME_APP_SECRET=

# Multiple WeChat Mini Games. Prefer this when one server hosts several games.
# WECHAT_MINIGAME_APPS='{"mahjong":{"appId":"wx-mahjong-appid","appSecret":"mahjong-secret"}}'

# Development only: bypass WeChat jscode2session and issue an internal token.
WECHAT_MINIGAME_MOCK_LOGIN=false
